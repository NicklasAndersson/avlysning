{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "avlysning",
  "compatibility_date": "2026-04-16",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "frontend/dist"
  },
  "build": {
    "command": "npm install && npm --prefix frontend run build"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
